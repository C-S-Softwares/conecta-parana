generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "linux-arm64-openssl-3.0.x"]
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis]
}

model HealthCheck {
  id        Int      @id @default(autoincrement())
  status    String
  checkedAt DateTime @default(now()) @map("checked_at")
  location  Unsupported("geometry(Point, 4326)")?

  @@map("health_checks")
}

model City {
  id_city Int @id @default(autoincrement())
  nome String
  state String

  users User[]
}

model User {
  id_user Int @id @default(autoincrement())
  name String 
  email String @unique 
  password String
  role Role @default(USUARIO)
  id_city Int 

  city City @relation(fields: [id_city], references: [id_city])
  Refresh_tokens Refresh_token[]
}

enum Role {
  ADMIN
  USUARIO
}

model Refresh_token {
  id_refresh_token Int @id @default(autoincrement())
  token String
  expires_at DateTime
  user_id Int

  user User @relation(fields: [user_id], references: [id_user])
}